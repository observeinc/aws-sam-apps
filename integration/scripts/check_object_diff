#!/bin/bash
# Write file to source bucket, verify it is copied over to destination bucket
set -euo pipefail

DIE() { echo "$*" 1>&2; exit 1; }

[[ ! -z "${SOURCE:-}" ]] || DIE "source not set"
[[ ! -z "${DESTINATION:-}" ]] || DIE "destination not set"

OBJECT_PREFIX=${OBJECT_PREFIX:-}
# jq expressions to apply to object metadata prior to diffing
# this allows us to filter out expected changes
JQ_PROCESS_SOURCE=${JQ_PROCESS_SOURCE:-.}
JQ_PROCESS_DESTINATION=${JQ_PROCESS_DESTINATION:-.}
MAX_COPY_ATTEMPTS=${MAX_COPY_ATTEMPTS:-10}
COPY_RETRY_INTERVAL=${COPY_RETRY_INTERVAL:-3}

if [ -n "${DEBUG:-}" ]; then
    set -x
fi

cleanup() {
    rm -f "$TMPFILE"
}

trap cleanup EXIT

TMPFILE=$(mktemp)

echo "{\"hello\": \"world\"}" > "$TMPFILE"

# we include source bucket name in key to help debug where file in destination bucket came from
KEY=${SOURCE}/${OBJECT_PREFIX}${TMPFILE}

aws s3 cp ${TMPFILE} s3://${SOURCE}/${KEY} --content-type application/json 1>&2 || DIE "failed to copy file to source"

sleep ${INIT_DELAY:-0}
ORIGINAL=$(aws s3api head-object --bucket ${SOURCE} --key ${KEY} | jq "del(.LastModified, .Expiration) | ${JQ_PROCESS_SOURCE}" || DIE "failed to read file from source")
sleep ${COPY_DELAY:-0}

attempt=1
while [ "${attempt}" -le "${MAX_COPY_ATTEMPTS}" ]; do
    if COPY=$(aws s3api head-object --bucket "${DESTINATION}" --key "${KEY}" 2>/dev/null | jq "del(.LastModified, .Expiration) | ${JQ_PROCESS_DESTINATION}" 2>/dev/null); then
        if [ "${ORIGINAL}" = "${COPY}" ]; then
            exit 0
        fi
        echo "destination object differs on attempt ${attempt}/${MAX_COPY_ATTEMPTS}" 1>&2
    else
        echo "destination object not available on attempt ${attempt}/${MAX_COPY_ATTEMPTS}" 1>&2
    fi

    if [ "${attempt}" -lt "${MAX_COPY_ATTEMPTS}" ]; then
        sleep "${COPY_RETRY_INTERVAL}"
    fi
    attempt=$((attempt + 1))
done

DIE "failed to read matching object from destination after ${MAX_COPY_ATTEMPTS} attempts"
